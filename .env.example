# ============================================================
# SafeGuard AI / CrimeVision-QA — Environment Configuration
# Copy this file to .env and fill in your actual keys.
# ============================================================

# ------------------------------------------------------------------
# REQUIRED: Fireworks AI
# Handles: Qwen2.5-VL-32B (vision), Whisper-v3 (transcription),
#          DeepSeek (query routing), thenlper/gte-large (embeddings)
# Obtain:  https://fireworks.ai
# ------------------------------------------------------------------
FIREWORKS_API_KEY=your_fireworks_api_key_here

# ------------------------------------------------------------------
# REQUIRED: MongoDB Atlas
# ------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=GenAI


# ------------------------------------------------------------------
# OPTIONAL: Voyage AI  (best embeddings — voyage-3-large, 1024-dim)
# Obtain:  https://dash.voyageai.com
# ------------------------------------------------------------------
VOYAGE_API_KEY=

# ------------------------------------------------------------------
# OPTIONAL: Google Gemini  (best reasoner — gemini-2.5-flash)
# NOTE: If your key is reported as leaked, set REASONER_PROVIDER=fireworks
# Obtain:  https://aistudio.google.com/app/apikey
# ------------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------------
# Provider toggles (resolved ONCE at startup, no per-request fallback)
# EMBED_PROVIDER:    "voyage" | "fireworks"  (default: fireworks)
# REASONER_PROVIDER: "gemini" | "fireworks"  (default: gemini if key set)
# ------------------------------------------------------------------
EMBED_PROVIDER=voyage
REASONER_PROVIDER=fireworks

# ------------------------------------------------------------------
# Paths (relative to project root)
# ------------------------------------------------------------------
VIDEO_FOLDER=./videos
FRAMES_FOLDER=./frames

# ------------------------------------------------------------------
# Server ports
# ------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=5173
